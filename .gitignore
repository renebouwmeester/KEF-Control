# build.sh installs straight to ~/Applications and builds via a temp dir,
# so there is nothing to ignore in-tree — these are just the usual suspects.
.DS_Store
*.app/
build/
dist/
*.zip

# Xcode (iOS target; project.yml is the source of truth, but the generated
# .xcodeproj is committed so a clone needs no xcodegen)
xcuserdata/
DerivedData/
